# Twitch API Credentials
CLIENT_ID=TWITCH_CLIENT_ID
CLIENT_SECRET=TWITCH_CLIENT_SECRET
BOT_USER_ID=BOT_USER_ID(not required)

KICK_CLIENT_ID=
KICK_CLIENT_SECRET=

KICK_API=https://api.kick.com
KICK_OAUTH=https://id.kick.com
KICK_WEBHOOK_PATH=
HTTP_SERVER_PORT=
ALLOW_KICK_INSECURE=false
# Set to true in dev to skip Kick webhook signature verification (NEVER in production)

# Admin panel links (optional, leave empty to hide buttons)
ADMINER_URL=
PGBACKWEB_URL=

# Twitch EventSub Configuration
SHARD_COUNT=1

# Telegram Bot Token
BOT_TOKEN=TELEGRAM_BOT_TOKEN

TWITCH_WS=TWITCH_WS_URL
TWITCH_HELIX=TWITCH_HELIX_URL
TWITCH_OAUTH=TWITCH_OAUTH_URL
DATABASE_URL=DATABASE_URL

# DEV ONLY — NEVER IN PRODUCTION
# Development endpoints (use in .env.dev):
# TWITCH_WS=ws://localhost:8081/ws
# TWITCH_HELIX=localhost:7777
# TWITCH_OAUTH=localhost:7777
#
# KICK_API=http://localhost:7777/kick
# KICK_OAUTH=http://localhost:7777/kick
#
# PROD
# TWITCH_WS=wss://eventsub.wss.twitch.tv/ws
# TWITCH_HELIX=https://api.twitch.tv/
# TWITCH_OAUTH=https://id.twitch.tv/
#
# # KICK_API=https://api.kick.com
# KICK_OAUTH=https://id.kick.com
