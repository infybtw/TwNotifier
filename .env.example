# Twitch API Credentials
CLIENT_ID=TWITCH_CLIENT_ID
CLIENT_SECRET=TWITCH_CLIENT_SECRET
BOT_USER_ID=BOT_USER_ID(not required)

KICK_CLIENT_ID=
KICK_CLIENT_SECRET=

KICK_API=https://api.kick.com
KICK_OAUTH=https://id.kick.com
KICK_WEBHOOK_PATH=
HTTP_SERVER_PORT=


# Admin panel links (optional, leave empty to hide buttons)
ADMINER_URL=
PGBACKWEB_URL=

# Twitch EventSub Configuration
SHARD_COUNT=1

# Twitch EventSub Transport: "webhook" or "conduit" (required)
TWITCH_EVENT_TRANSPORT=

# Webhook config (required when TWITCH_EVENT_TRANSPORT=webhook)
TWITCH_WEBHOOK_PATH=
TWITCH_WEBHOOK_SECRET=
BOT_URL=https://your-domain.com

# Telegram Bot Token
BOT_TOKEN=TELEGRAM_BOT_TOKEN

TWITCH_WS=TWITCH_WS_URL
TWITCH_HELIX=TWITCH_HELIX_URL
TWITCH_OAUTH=TWITCH_OAUTH_URL
DATABASE_URL=DATABASE_URL

# Default language for new users (ru or en)
DEFAULT_LANGUAGE=ru
